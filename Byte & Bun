 import promptSync from 'prompt-sync'
const prompt = promptSync
let faturamentoTotal = 0;
let totalItensVendidos = 0;
let escolha = -1;

// Função 1
function gerarDivisor(caracter, tamanho) {
    let linha = "";

    for (let i = 0; i < tamanho; i++) {
        linha += caracter;
    }

    return linha;
}

// Função 2
function calcularPrecoItem(codigo, quantidade) {
    let preco = 0;

    switch (codigo) {
        case 1:
            preco = 25;
            break;
        case 2:
            preco = 15;
            break;
        case 3:
            preco = 8;
            break;
        default:
            console.log("Código inválido!");
            return 0;
    }

    return preco * quantidade;
}

// Função 3
function calcularDesconto(valor) {
    if (valor >= 60) {
        return valor * 0.10;
    }

    return 0;
}

// Função 4
function exibirBoasVindas() {
    console.clear();
    console.log(gerarDivisor("=", 40));
    console.log("        BEM-VINDO AO BYTE & BUN");
    console.log(gerarDivisor("=", 40));
}

// Função 5
function registrarPedido() {
    let codigo = Number(prompt(
        "Digite o código do item:\n" +
        "1 - Hambúrguer (R$25)\n" +
        "2 - Batata (R$15)\n" +
        "3 - Refrigerante (R$8)"
    ));

    let quantidade = Number(prompt("Digite a quantidade:"));

    let valorItem = calcularPrecoItem(codigo, quantidade);

    return {
        valorItem,
        quantidade
    };
}

// Função 6
function menuPrincipal() {

    while (escolha !== 0) {

        exibirBoasVindas();

        console.log("0 - Fechar turno");
        console.log("1 - Registrar item");

        escolha = Number(prompt("Escolha uma opção:"));

        if (escolha === 1) {

            let pedido = registrarPedido();

            if (pedido.valorItem > 0) {
                faturamentoTotal += pedido.valorItem;
                totalItensVendidos += pedido.quantidade;

                console.log(`Pedido registrado: R$ ${pedido.valorItem.toFixed(2)}`);
            }

            prompt("Pressione ENTER para continuar...");
        }
    }

    let desconto = calcularDesconto(faturamentoTotal);
    let faturamentoLiquido = faturamentoTotal - desconto;

    console.clear();
    console.log(gerarDivisor("=", 40));
    console.log("           FECHAMENTO DO CAIXA");
    console.log(gerarDivisor("=", 40));
    console.log(`Itens vendidos: ${totalItensVendidos}`);
    console.log(`Faturamento bruto: R$ ${faturamentoTotal.toFixed(2)}`);
    console.log(`Desconto: R$ ${desconto.toFixed(2)}`);
    console.log(`Faturamento líquido: R$ ${faturamentoLiquido.toFixed(2)}`);
    console.log(gerarDivisor("=", 40));
}

menuPrincipal();
