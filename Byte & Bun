let quantidade
let valorItem
let faturamentoTotal = 0
let totalItensVendidos = 0
let escolha
let subTotal = 0 // Inicializado com 0
let faturamentoLiquido

// Função 1
function gerarDivisor (caracter, tamanho){
    linha = "" 
    for (let i = 0 ; i <= tamanho ; i++){
        linha = linha + caracter
    }
   return linha
}

// Função 2
function calcularPrecoItem(codigo, quantidade) {
    switch(codigo){
        case 1:
            item = 25
            break
        case 2: 
            item = 15
            break
        case 3:
            item = 8
            break
        default: // Substituído o case inválido por default
            item = 0 
            break
    }
    precoItem = item * quantidade
    return precoItem
}

// Função 3 
function calcularDesconto(subTotal){
    if (subTotal >= 60){
        desconto = subTotal * (10/100)
    } else {
        desconto = 0 // Garante que zera se o valor for menor que 60
    }
    return desconto
} 

// Função 4
function exibirBoasVindas() {
    console.log(gerarDivisor("=",39))
    console.log("--- BEM-VINDO AO GERENTE BYTE & BUN ---")
    console.log(gerarDivisor("=", 39))
}

// Função 5
function registrarPedido(){
    codigo = Number(prompt("Digite o código do item:\n(1) Hambúrguer\n(2) Batata\n(3) Refrigerante"))
    quantidade = Number(prompt("Digite a quantidade de itens: "))
    calcularPrecoItem(codigo, quantidade)
    valorItem = precoItem
    return valorItem
}

// Função 6
function menuPrincipal(){
    while(escolha != 0){
        exibirBoasVindas()
        console.log("0. Fechar turno e sair")
        console.log("1. Registrar item")
        escolha = prompt("Escolha uma opção:")
        console.clear()
        
        if (escolha == 1) {
            registrarPedido()
            subTotal = valorItem
            
            if (subTotal > 0) {
                faturamentoTotal = faturamentoTotal + subTotal
                totalItensVendidos = totalItensVendidos + quantidade // Soma a quantidade real de itens
            }
        }
    }

    // Fechamento do caixa
    calcularDesconto(faturamentoTotal)
    faturamentoLiquido = faturamentoTotal - desconto

    console.clear()
    console.log(gerarDivisor("=", 40))
    console.log("          --- BYTE-BUN ---          ")
    console.log(gerarDivisor("=", 40))
    console.log(`Quantidade total de itens vendidos: ${totalItensVendidos}`)
    console.log(`Faturamento bruto: R$ ${faturamentoTotal.toFixed(2)}`)
    console.log(`Desconto: R$ ${desconto.toFixed(2)}`)
    console.log(`Faturamento líquido: R$ ${faturamentoLiquido.toFixed(2)}`)
    console.log(gerarDivisor("=", 40))
}

menuPrincipal()

